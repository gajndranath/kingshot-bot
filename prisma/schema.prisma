generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GuildConfig {
  guild_id           String        @id
  kingdom_number     Int?
  kingdom_age        Int?
  alliance_tag       String?
  academy_tag        String?       // NEW: Solo Mode Academy Tag
  mode               String        @default("SOLO") // "SOLO" or "KINGDOM"
  alert_channel      String?       // General Alert Channel
  events_channel     String?       // #events-feed
  war_room_channel   String?       // #war-room
  bear_hunt_channel  String?       // #bear-hunt
  gift_codes_channel String?       // #gift-codes
  strategy_channel   String?       // #strategy-guides
  audit_channel      String?       // R4 action logs
  trivia_channel     String?       // Dead channel revival
  diplomacy_channel  String?       // NAP Violation Alerts
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  
  subscription       Subscription?
  members            Member[]
  events             Event[]
  votes              Vote[]
  nap_alliances      NAPAlliance[]
  banned_players     BannedPlayer[]
  feedbacks          Feedback[]
}

model NAPAlliance {
  id          String   @id @default(uuid())
  guild_id    String
  tag         String   @db.VarChar(5)
  academy_tag String?  @db.VarChar(5) // NEW: Kingdom Mode Academy Tag
  added_by    String   // Discord ID of R5 who added it
  expires_at  DateTime?
  created_at  DateTime @default(now())

  guild       GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)

  @@unique([guild_id, tag])
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique // e.g., "Basic", "Premium", "Monthly", "Lifetime"
  price         Float    @default(0.0)
  billing_cycle String   @default("MONTHLY") // "ONE_TIME", "MONTHLY", "YEARLY"
  trial_days    Int      @default(0) // 0 means no trial
  features      String?  // JSON string or comma separated features
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  subscriptions Subscription[]
  payments      PaymentRecord[]
}

model Subscription {
  id              String      @id @default(uuid())
  guild_id        String      @unique
  guild           GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
  plan_id         String?
  plan            SubscriptionPlan? @relation(fields: [plan_id], references: [id])
  is_premium      Boolean     @default(false)
  status          String      @default("TRIAL") // "TRIAL", "ACTIVE", "EXPIRED", "FRAUD"
  trial_expires   DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
}

model PaymentRecord {
  id              String      @id @default(uuid())
  guild_id        String
  user_id         String      // Discord ID of the person who paid
  plan_id         String
  plan            SubscriptionPlan @relation(fields: [plan_id], references: [id])
  amount_paid     Float
  payment_method  String      @default("MANUAL") // "MANUAL", "STRIPE", "PAYPAL"
  status          String      @default("COMPLETED") // "COMPLETED", "FAILED", "FRAUD_ATTEMPT"
  transaction_id  String?     @unique
  notes           String?
  created_at      DateTime    @default(now())
}

model SuperAdmin {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model Member {
  id              String      @id @default(uuid())
  discord_id      String
  guild_id        String
  guild           GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
  in_game_name    String
  in_game_id      String?     // NEW: Permanent identifier for bans
  alliance_tag    String?     // E.g., [K99] - Used mostly in Kingdom Mode
  alliance_type   String      @default("MAIN") // NEW: MAIN or ACADEMY
  role            String      @default("MEMBER") // "R4", "R5", "MEMBER"
  is_verified     Boolean     @default(false)
  is_weekend_warrior Boolean  @default(false)
  has_used_free_kvk Boolean   @default(false)
  activity_score  Int         @default(0)
  last_active     DateTime    @default(now())
  last_checkin    DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@unique([discord_id, guild_id])
}

model Event {
  id              String      @id @default(uuid())
  guild_id        String
  guild           GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
  name            String
  description     String?
  scheduled_time  DateTime
  channel_id      String?
  created_by      String
  reminder_sent   Boolean     @default(false)
  
  rsvps           EventRSVP[]
}

model EventRSVP {
  id          String   @id @default(uuid())
  event_id    String
  discord_id  String
  troop_type  String   // "INFANTRY", "LANCER", "MARKSMAN"
  created_at  DateTime @default(now())
  
  event       Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  
  @@unique([event_id, discord_id])
}

model Vote {
  id              String      @id @default(uuid())
  guild_id        String
  guild           GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
  topic           String
  restricted_to   String      // e.g., "R4"
  closes_at       DateTime
}

model BannedPlayer {
  id              String      @id @default(uuid())
  guild_id        String
  guild           GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
  in_game_id      String
  banned_by       String      // Discord ID of R4/R5
  reason          String?
  created_at      DateTime    @default(now())

  @@unique([guild_id, in_game_id])
}

model Feedback {
  id          String      @id @default(uuid())
  guild_id    String
  user_id     String
  issue_text  String      @db.Text
  is_resolved Boolean     @default(false)
  created_at  DateTime    @default(now())
  
  guild       GuildConfig @relation(fields: [guild_id], references: [guild_id], onDelete: Cascade)
}
